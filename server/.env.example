# Supabase (обязательно)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# API-ключ для защищённых эндпоинтов /stats и /responses
# Если не задан — эндпоинты открыты (только для разработки)
STATS_API_KEY=

# Telegram-бот (опционально)
# 1. Создайте бота через @BotFather → получите TELEGRAM_BOT_TOKEN
# 2. Добавьте бота в нужный чат/группу и напишите /chatid → получите TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Прочее
PORT=3000
NODE_ENV=production
